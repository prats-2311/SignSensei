rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. User Profile Rules
    match /users/{userId} {
      // Users can only read, create, and update their own documents
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 2. Dynamic Decks Rules
    match /decks/{deckId} {
      // Anyone can read if the deck is public. The creator can read their private decks.
      allow read: if resource == null || resource.data.isPublic == true || (request.auth != null && request.auth.uid == resource.data.creatorId);
      
      // A user can create a deck if they set themselves as the creator Id
      allow create: if request.auth != null && request.auth.uid == request.resource.data.creatorId;
      
      // A user can toggle privacy or update only on their own decks
      allow update: if request.auth != null && request.auth.uid == resource.data.creatorId;
      
      // A user can ONLY delete a deck if they created it
      allow delete: if request.auth != null && request.auth.uid == resource.data.creatorId;
    }

  }
}
